{
  "index_uid": "jinqiu-wang",
  "start_urls": [
    "https://jinqiu.wang/"
  ],
  "sitemap_urls": [
    "https://jinqiu.wang/sitemap.xml"
  ],
  "selectors": {
    "lvl0": {
      "selector": "[vp-content] h1",
      "global": true,
      "default_value": "Documentation"
    },
    "lvl1": "[vp-content] h2",
    "lvl2": "[vp-content] h3",
    "content": "[vp-content] p, [vp-content] li",
    "lang": {
      "selector": "/html/@lang",
      "global": true,
      "type": "xpath"
    }
  },
  "custom_settings": {
    "filterableAttributes": [
      "lang"
    ]
  }
}